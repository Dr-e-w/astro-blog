---
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        background: #ffffff;
        color: #1a1a1a;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto",
          "Oxygen", "Ubuntu", "Cantarell", "Fira Sans", "Droid Sans",
          "Helvetica Neue", sans-serif;
      }

      .blog-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0;
        background: #ffffff;
      }

      .header {
        padding: 64px 40px 48px;
        border-bottom: 1px solid #e5e5e5;
        background: linear-gradient(135deg, #fafafa 0%, #ffffff 100%);
      }

      .header-content {
        max-width: 1000px;
        margin: 0 auto;
      }

      .logo {
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.8px;
        margin-bottom: 20px;
        position: relative;
        padding-bottom: 16px;
      }

      .logo::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 40px;
        height: 3px;
        background: #1a1a1a;
        border-radius: 2px;
      }

      .header-intro {
        font-size: 16px;
        line-height: 1.7;
        color: #555;
        max-width: 650px;
        font-weight: 400;
      }

      .main-grid {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 64px;
        max-width: 1000px;
        margin: 0 auto;
        padding: 64px 40px;
      }

      .sidebar {
        position: sticky;
        top: 48px;
        height: fit-content;
      }

      .sidebar-section {
        margin-bottom: 48px;
      }

      .sidebar-section:first-child {
        margin-top: 0;
      }

      .sidebar-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: #999;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
      }

      .sidebar-label::before {
        content: "";
        width: 8px;
        height: 8px;
        background: #1a1a1a;
        border-radius: 50%;
        margin-right: 8px;
      }

      .sidebar-list {
        list-style: none;
      }

      .sidebar-list li {
        margin-bottom: 14px;
      }

      .sidebar-list a {
        font-size: 14px;
        color: #1a1a1a;
        text-decoration: none;
        line-height: 1.5;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
        padding-left: 0;
      }

      .sidebar-list a:hover {
        color: #666;
        padding-left: 4px;
      }

      .sidebar-list a.active {
        color: #333;
        font-weight: 600;
        padding-left: 6px;
        border-left: 2px solid #1a1a1a;
      }

      .posts {
        flex: 1;
      }

      .post-card {
        padding: 36px 0;
        border-bottom: 1px solid #f0f0f0;
        transition: all 0.2s;
        cursor: pointer;
        position: relative;
      }

      .post-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        width: 3px;
        height: 0;
        background: #1a1a1a;
        transition: height 0.3s;
      }

      .post-card:hover::before {
        height: 100%;
      }

      .post-card:hover {
        padding-left: 12px;
      }

      .post-card:last-child {
        border-bottom: none;
      }

      .post-date {
        font-size: 12px;
        color: #aaa;
        margin-bottom: 10px;
        font-weight: 500;
        letter-spacing: 0.5px;
      }

      .post-title {
        font-size: 20px;
        font-weight: 600;
        line-height: 1.35;
        margin-bottom: 12px;
        color: #1a1a1a;
        letter-spacing: -0.3px;
      }

      .post-excerpt {
        font-size: 15px;
        line-height: 1.65;
        color: #666;
        margin-bottom: 16px;
      }

      .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .post-tag {
        font-size: 12px;
        padding: 6px 12px;
        background: #f8f8f8;
        border: 0.5px solid #e8e8e8;
        border-radius: 12px;
        color: #777;
        font-weight: 500;
        transition: all 0.2s;
      }

      .post-tag:hover {
        background: #efefef;
        border-color: #ddd;
      }

      .posts-header {
        margin-bottom: 40px;
        padding-bottom: 32px;
        border-bottom: 2px solid #e5e5e5;
        position: relative;
      }

      .posts-header::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 60px;
        height: 2px;
        background: #1a1a1a;
      }

      .posts-header h1 {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: -0.5px;
      }

      .posts-count {
        font-size: 14px;
        color: #999;
        font-weight: 500;
      }

      @media (max-width: 768px) {
        .main-grid {
          grid-template-columns: 1fr;
          gap: 40px;
          padding: 40px 20px;
        }

        .sidebar {
          position: relative;
          top: 0;
        }

        .header {
          padding: 40px 20px 32px;
        }

        .post-card:hover {
          padding-left: 0;
        }

        .post-card::before {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="blog-container">
      <slot />
    </div>
  </body>
</html>
